# ====================================================================
# GoodMonk Command Center — local env (copy to .env, never commit .env)
# On GitHub these become repository Secrets instead.
# ====================================================================

# Site under test
GM_BASE_URL=https://goodmonk.in

# Google PageSpeed Insights API key (System 2)
PAGESPEED_API_KEY=

# Google Sheets logging
GOOGLE_SHEET_ID=
# Paste the FULL service-account JSON on one line (or as a GitHub secret)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Gmail SMTP alerts
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
ALERT_RECIPIENTS=ops1@goodmonk.in,dev-owner@goodmonk.in

# Optional tuning
ALERT_DEDUP_MINUTES=120
